{
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/huagui_company_site/assets/$1"
    },
    {
      "source": "/(.*).html",
      "destination": "/huagui_company_site/$1.html"
    },
    {
      "source": "/",
      "destination": "/huagui_company_site/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/huagui_company_site/$1"
    }
  ]
}

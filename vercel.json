{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/huagui_company_site/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/huagui_company_site/assets/$1"
    },
    {
      "source": "/(.*).html",
      "destination": "/huagui_company_site/$1.html"
    },
    {
      "source": "/",
      "destination": "/huagui_company_site/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/huagui_company_site/$1"
    }
  ]
}
